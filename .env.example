# Cognitive OS Environment Variables
# Copy this file to .env and fill in real values

# ── PostgreSQL (Neon) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require

# ── ChromaDB (optional vector store) ──────────────────────────────────────
VECTORDB_HOST=localhost
CHROMA_PORT=8001

# ── Auth ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# ── Ollama (local LLM inference) ───────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OPENAI_API_KEY=sk-xxxx... # For Cognitive Memory Engine embeddings

# ── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_ENDPOINT=http://localhost:8000