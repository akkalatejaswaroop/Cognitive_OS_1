# Cognitive OS Environment Variables
# Copy this file to .env and fill in real values

# ── PostgreSQL (Neon) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:npg_o4ARTSGqsm0W@ep-mute-mountain-ak7nhohq-pooler.c-3.us-west-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# ── ChromaDB (optional vector store) ──────────────────────────────────────
CHROMA_SERVER_HOST=localhost
CHROMA_SERVER_HTTP_PORT=8001

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# ── Ollama (local LLM inference) ───────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ── Frontend ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
